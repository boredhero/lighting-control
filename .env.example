# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/lighting.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Data storage
DATA_DIR=/app/data

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=changeme

# WebAuthn
WEBAUTHN_RP_ID=lights.martinospizza.dev
WEBAUTHN_RP_NAME=Lighting Control Dashboard
WEBAUTHN_ORIGIN=https://lights.martinospizza.dev

# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# Device discovery interval (seconds)
DISCOVERY_INTERVAL_SECONDS=60
